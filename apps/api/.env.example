PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/email_saas?schema=public
REDIS_URL=redis://localhost:6379

# BullMQ campaign-send worker (separate process: npm run worker --workspace @email-saas/api)
# CAMPAIGN_BATCH_SIZE=25
# CAMPAIGN_WORKSPACE_EMAILS_PER_MINUTE=120
# CAMPAIGN_MESSAGE_MAX_RETRIES=3
# CAMPAIGN_MESSAGE_RETRY_BASE_MS=2000
# CAMPAIGN_WORKER_CONCURRENCY=2
# CAMPAIGN_WORKER_GLOBAL_JOBS_PER_SEC=20
# Sequence queue (same worker process)
# SEQUENCE_WORKER_CONCURRENCY=3
# SEQUENCE_WORKER_GLOBAL_JOBS_PER_SEC=30
JWT_SECRET=super-secret-jwt-key
# HMAC/hash pepper for email verification & password reset tokens (prefer distinct from JWT in prod)
# AUTH_TOKEN_PEPPER=long-random-pepper

# Optional Cloudflare Turnstile — when set, register & forgot-password require `turnstileToken` in JSON body
# TURNSTILE_SECRET_KEY=
# Max CSV upload size for POST /contacts/import-csv (bytes)
CSV_IMPORT_MAX_BYTES=1048576

# Mail: console (default) = log only; smtp = Nodemailer (MailHog / real SMTP)
MAIL_MODE=console
MAIL_FROM=noreply@localhost

# When MAIL_MODE=smtp (optional — MailHog: host localhost, port 1025, no auth)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Public web origin for links in emails (must match Next.js URL, no trailing slash)
PUBLIC_WEB_URL=http://localhost:3000

# HMAC secret for unsubscribe tokens (required for compliance links + GET /unsubscribe)
UNSUBSCRIBE_SECRET=change-me-unsubscribe-hmac-secret

# Optional token TTL in days (omit or 0 = no expiry)
# UNSUBSCRIBE_TOKEN_TTL_DAYS=365

# Inbound mail webhooks (POST /webhooks/mail/*) — header X-Webhook-Secret must match
WEBHOOK_MAIL_SECRET=change-me-webhook-secret
# Max webhook requests per IP per minute (in-memory; use Redis limiter at scale)
# WEBHOOK_MAIL_MAX_PER_MINUTE_IP=120

# Optional: SendGrid Event Webhook ECDSA public key (verification stub — implement or use secret-only)
# SENDGRID_WEBHOOK_PUBLIC_KEY=

# --- Stripe (subscriptions, server-only secrets) ---
# Test mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price id for Pro monthly recurring price (test mode price_...)
STRIPE_PRICE_PRO_MONTHLY=
# Full URLs shown after Checkout / Portal (defaults: PUBLIC_WEB_URL + /dashboard/billing)
# STRIPE_SUCCESS_URL=http://localhost:3000/dashboard/billing?checkout=success
# STRIPE_CANCEL_URL=http://localhost:3000/dashboard/billing?checkout=cancel
# STRIPE_PORTAL_RETURN_URL=http://localhost:3000/dashboard/billing
