NEXT_PUBLIC_API_URL=http://localhost:4000
# Canonical site URL for OpenGraph + email links (no trailing slash)
NEXT_PUBLIC_WEB_URL=http://localhost:3000
# GitHub project Pages only: URL path prefix, e.g. /my-repo (leading slash, no trailing slash).
# Must match NEXT_PUBLIC_WEB_URL origin path (see README “GitHub Pages”).
# NEXT_PUBLIC_BASE_PATH=
# Optional: Cloudflare Turnstile site key when wiring the widget (see README)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
